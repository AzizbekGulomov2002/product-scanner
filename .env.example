# Copy to .env and edit for your server

SECRET_KEY=change-me-in-production
DEBUG=False
# No port in ALLOWED_HOSTS — only IP/hostname
ALLOWED_HOSTS=YOUR_SERVER_IP,localhost,127.0.0.1

# PostgreSQL + pgvector (required for AI search)
POSTGRES_DB=product_searcher
POSTGRES_USER=ps_user
POSTGRES_PASSWORD=ChangeMeStrongPass123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis + Celery background embeddings
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# False = Celery worker embeds in background (admin Save stays fast)
# True = still non-blocking (daemon thread), but no Redis worker needed
CELERY_TASK_ALWAYS_EAGER=False

# Telegram — https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
BACKEND_URL=http://YOUR_SERVER_IP:8888
WEBAPP_URL=http://YOUR_SERVER_IP:8888

# Search thresholds
CONFIDENCE_HIGH=0.88
CONFIDENCE_MEDIUM=0.82
CONFIDENCE_MIN_GAP=0.06
REALTIME_CONFIDENCE_HIGH=0.80
REALTIME_CONFIDENCE_MIN=0.72
REALTIME_CONFIDENCE_MIN_GAP=0.04
SEARCH_TOP_K=5

# CLIP model
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai

# Production — keep workers=1 on small servers
GUNICORN_BIND=0.0.0.0:8888
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=180
